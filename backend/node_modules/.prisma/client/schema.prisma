// ==============================================
// SpaceV SaaS - Prisma Database Schema
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================================
// FiveM RP Player Models
// ==============================================

// RP Player - Links FiveM player to website user
model RPPlayer {
  id         Int       @id @default(autoincrement())
  userId     Int?      @unique // Link to website user (optional)
  license    String    @unique // FiveM license identifier
  discordId  String?   @unique // Discord ID for avatar
  steamId    String?   @unique
  liveId     String?   @unique
  xboxId     String?   @unique
  playerName String // In-game name
  avatar     String?
  rpScore    Int       @default(1000) // Roleplay score
  isBanned   Boolean   @default(false)
  banReason  String?
  bannedAt   DateTime?
  bannedBy   String?
  lastSeen   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  stats           PlayerStats?
  job             PlayerJob?
  assets          PlayerAsset[]
  inventory       PlayerInventoryItem[]
  anticheatEvents AntiCheatEvent[]

  @@map("rp_players")
}

// Player Statistics
model PlayerStats {
  id             Int      @id @default(autoincrement())
  playerId       Int      @unique
  money          Decimal  @default(0) @db.Decimal(15, 2)
  bank           Decimal  @default(0) @db.Decimal(15, 2)
  blackMoney     Decimal  @default(0) @db.Decimal(15, 2)
  playtime       Int      @default(0) // In minutes
  kills          Int      @default(0)
  deaths         Int      @default(0)
  vehiclesOwned  Int      @default(0)
  housesOwned    Int      @default(0)
  totalPurchases Int      @default(0)
  inventoryValue Decimal  @default(0) @db.Decimal(15, 2)
  totalEarnings  Decimal  @default(0) @db.Decimal(15, 2)
  totalSpent     Decimal  @default(0) @db.Decimal(15, 2)
  lastUpdated    DateTime @default(now())

  player RPPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

// Player Job
model PlayerJob {
  id          Int      @id @default(autoincrement())
  playerId    Int      @unique
  job         String   @default("unemployed")
  jobGrade    Int      @default(0)
  jobLabel    String   @default("Unemployed")
  onDuty      Boolean  @default(false)
  salary      Decimal  @default(0) @db.Decimal(10, 2)
  lastUpdated DateTime @default(now())

  player RPPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_jobs")
}

// Player Assets (Vehicles, Houses)
model PlayerAsset {
  id         Int       @id @default(autoincrement())
  playerId   Int
  type       AssetType
  name       String
  label      String
  value      Decimal   @default(0) @db.Decimal(15, 2)
  properties Json? // Additional properties (vehicle: plate, house: address, etc.)
  createdAt  DateTime  @default(now())

  player RPPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_assets")
}

enum AssetType {
  VEHICLE
  HOUSE
  BUSINESS
}

// Player Inventory Items
model PlayerInventoryItem {
  id        Int               @id @default(autoincrement())
  playerId  Int
  name      String
  label     String
  count     Int               @default(1)
  category  InventoryCategory @default(ITEM)
  metadata  Json? // Item metadata (durability, etc.)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  player RPPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_inventory")
}

enum InventoryCategory {
  WEAPON
  ITEM
  FOOD
  DRINK
  MEDICAL
  CLOTHING
  VEHICLE
  KEY
  DOCUMENT
  OTHER
}

// Anti-Cheat Events
model AntiCheatEvent {
  id           Int           @id @default(autoincrement())
  playerId     Int
  playerName   String
  license      String
  event        String
  eventType    AntiCheatType
  severity     Severity
  value        Decimal?      @db.Decimal(15, 2)
  details      Json? // Additional event details
  evidence     String?       @db.Text // Evidence log
  flagged      Boolean       @default(false)
  resolved     Boolean       @default(false)
  resolvedBy   String?
  resolvedAt   DateTime?
  discordAlert Boolean       @default(false)
  createdAt    DateTime      @default(now())

  player RPPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("anticheat_events")
}

enum AntiCheatType {
  MONEY_EXPLOIT
  ITEM_DUPLICATION
  TELEPORT_HACK
  SPEED_HACK
  SUSPICIOUS_ADMIN_COMMAND
  INVENTORY_OVERFLOW
  IMPOSSIBLE_JOB_PAYOUT
  VEHICLE_SPEED_HACK
  GOD_MODE
  INVISIBILITY_HACK
  WEAPON_EXPLOIT
  BLIP_EXPLOIT
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// FiveM Server Configuration
model FiveMServer {
  id            Int       @id @default(autoincrement())
  name          String
  apiKey        String    @unique
  ipAddress     String?
  port          Int?
  isActive      Boolean   @default(true)
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("fivem_servers")
}

// Webhook for Discord alerts
model DiscordWebhook {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  type      String // "anticheat", "leaderboard", "general"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("discord_webhooks")
}

// ==============================================
// User Model
// ==============================================
model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  username          String    @unique
  password          String?
  discordId         String?   @unique
  discordUsername   String?
  avatar            String?
  role              Role      @default(USER)
  emailVerified     Boolean   @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  orders         Order[]
  invoices       Invoice[]
  notifications  Notification[]
  sessions       Session[]
  linkedAccounts LinkedAccount[]

  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  OWNER
}

// ==============================================
// Session Model (for persistent login)
// ==============================================
model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==============================================
// Linked Account Model (Discord, etc.)
// ==============================================
model LinkedAccount {
  id           Int       @id @default(autoincrement())
  userId       Int
  provider     String // "discord", "google", etc.
  providerId   String // ID from the provider
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("linked_accounts")
}

// ==============================================
// Product Category Model
// ==============================================
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ==============================================
// Product Model
// ==============================================
model Product {
  id             Int         @id @default(autoincrement())
  name           String
  slug           String      @unique
  description    String?     @db.Text
  price          Decimal     @db.Decimal(10, 2)
  image          String?
  TebexPackageId Int? // Tebex package ID for sync
  categoryId     Int?
  type           ProductType @default(ITEM)
  isActive       Boolean     @default(true)
  isFeatured     Boolean     @default(false)
  sortOrder      Int         @default(0)
  metadata       Json? // For additional product data (game items, etc.)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

enum ProductType {
  RANK // VIP ranks
  ITEM // In-game items
  BUNDLE // Package deals
  CURRENCY // Virtual currency
}

// ==============================================
// Order Model
// ==============================================
model Order {
  id                 Int         @id @default(autoincrement())
  orderId            String      @unique // Tebex order ID
  userId             Int?
  guestEmail         String?
  status             OrderStatus @default(PENDING)
  total              Decimal     @db.Decimal(10, 2)
  currency           String      @default("USD")
  paymentMethod      String?
  TebexTransactionId String?
  customerName       String?
  customerEmail      String?
  customerIp         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user    User?       @relation(fields: [userId], references: [id])
  items   OrderItem[]
  invoice Invoice?

  @@map("orders")
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
  FRAUDULENT
}

// ==============================================
// Order Item Model
// ==============================================
model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ==============================================
// Invoice Model
// ==============================================
model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  orderId       Int           @unique
  userId        Int?
  status        InvoiceStatus @default(PENDING)
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  pdfPath       String?
  sentAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  VOID
}

// ==============================================
// Notification Model
// ==============================================
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  ORDER
  SYSTEM
  SECURITY
  PROMO
}

// ==============================================
// Analytics Model (for dashboard stats)
// ==============================================
model Analytics {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique @default(now())
  pageViews      Int      @default(0)
  uniqueVisitors Int      @default(0)
  ordersCount    Int      @default(0)
  revenue        Decimal  @default(0) @db.Decimal(10, 2)
  newUsers       Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("analytics")
}

// ==============================================
// Site Settings Model
// ==============================================
model SiteSettings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

// ==============================================
// Webhook Log Model
// ==============================================
model WebhookLog {
  id        Int      @id @default(autoincrement())
  provider  String // "tebex", "discord", etc.
  eventType String
  payload   Json
  processed Boolean  @default(false)
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@map("webhook_logs")
}

# ==============================================
# SpaceV Environment Configuration Example
# ==============================================
# Copy this file to .env and fill in your values

# Database Configuration (MySQL via XAMPP)
DATABASE_URL="mysql://root:@127.0.0.1:3306/tebx"

# JWT Configuration
JWT_SECRET=change_this_to_a_random_secret_key
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=SpaceV <noreply@yourdomain.com>

# Tebex Configuration
TEBEX_STORE_URL=https://your-store.tebex.io
TEBEX_API_SECRET=your_tebex_api_secret
TEBEX_WEBHOOK_SECRET=your_tebex_webhook_secret

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook_url

# Discord OAuth Configuration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Site Configuration
SITE_URL=http://localhost:3000
SITE_NAME=SpaceV

